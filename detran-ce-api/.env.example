PORT=3000
API_KEY=troque_essa_chave
PLANILHA_PATH=./data/veiculos.xlsx
HEADLESS=true
DETRAN_BASE_URL=https://sistemas.detran.ce.gov.br/central
DETRAN_CONSULTA_URL=https://sistemas.detran.ce.gov.br/central
DETRAN_ABA_TEXTO=Veiculos
DETRAN_SERVICO_TEXTO=Taxas / Multas
# Numero de consultas Detran rodando em paralelo (padrao: 3)
MONITOR_CONCORRENCIA=3
PLAYWRIGHT_TIMEOUT_MS=20000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=45000
PLAYWRIGHT_CLICK_DELAY_MS=500
PLAYWRIGHT_FORM_POLL_MS=300
PLAYWRIGHT_RESULT_DELAY_MS=1200
PLAYWRIGHT_FORM_FIELD_TIMEOUT_MS=700

MONITOR_LOG_PATH=./data/pendencias-log.json
MONITOR_MESSAGE_PATH=./data/ultima-mensagem.txt

TACOGRAFO_URL=https://cronotacografo.rbmlq.gov.br/certificados/consultar
TACOGRAFO_DIAS_ALERTA=15
TACOGRAFO_CAPTCHA_TIMEOUT_MS=12000
TACOGRAFO_LOG_PATH=./data/tacografo-log.json
TACOGRAFO_MESSAGE_PATH=./data/ultima-mensagem-tacografo.txt

# API de resolucao de CAPTCHA (escolha uma)
# CapSolver: https://capsolver.com  (~$1.80/1000 captchas)
# 2captcha:  https://2captcha.com   (~$2.99/1000 captchas)
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=

# Forcar execucao do tacografo independente do dia da semana (para testes)
FORCAR_TACOGRAFO=false
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
NOTIFY_WEBHOOK_ENABLED=false
NOTIFY_WEBHOOK_URL=

# WhatsApp via Evolution API
# Instale e configure o Evolution API: https://github.com/EvolutionAPI/evolution-api
WHATSAPP_ENABLED=false
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
# Lista de destinatarios separados por virgula (numeros e/ou grupos)
# Numero: formato internacional sem + (ex: 5585999999999)
# Grupo:  ID_DO_GRUPO@g.us (obtenha via API: GET /group/fetchAllGroups/instancia)
# Exemplo: WHATSAPP_NUMBERS=5585999990001,5585999990002,120363XXXXXXXXXX@g.us
WHATSAPP_NUMBERS=
# Coluna "whatsapp" na planilha: numero ou JID de grupo para alertas especificos por veiculo
